# ==================== MCP Server 环境变量配置 ====================

# 服务器基本配置
MCP_SERVER_NAME=mcp-real-server
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
MCP_TRANSPORT=sse           # 传输模式: stdio | sse
MCP_LOG_LEVEL=INFO          # 日志级别: DEBUG | INFO | WARNING | ERROR

# 工具配置
ENABLE_WEATHER_TOOL=true
ENABLE_CALCULATOR_TOOL=true
ENABLE_TEXT_TOOL=true
ENABLE_WEB_SEARCH_TOOL=true

# 天气工具 API (可选，默认使用免费的 Open-Meteo)
# WEATHER_API_KEY=your_api_key_here

# 部署配置
WORKERS=4                   # Uvicorn worker 数量 (生产环境建议 CPU核数*2+1)
